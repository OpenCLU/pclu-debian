start_up = proc()
	po: stream := stream$primary_output()
	stream$putl(po, "Hello World!")
	s: string := "0123456789"
	stream$putl(po, s)
	fn: file_name := file_name$create(".", "test", "gc", "")
	stream$putl(po, "Hello World!")
	gc_dump[string](s, fn)
	stream$putl(po, "Hello World!")
	ns: string := gc_read[string](fn)
	stream$putl(po, ns)
	_exit(0)
end start_up
